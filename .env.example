# Parser runtime mode
# Allowed mess names to monitor (comma separated)
ALLOWED_MESS_NAMES=neelkesh,firstman

# Meal mode:
# - all: accept lunch+dinner mentions; no meal fallback
# - lunch/dinner: if meal missing in text, fallback to this mode
ACTIVE_MEAL_MODE=all

# Optional alias map for fuzzy name detection (JSON object)
# MESS_ALIASES_JSON={"neelkesh":["neelksh","neelakesh"],"firstman":["fristman","firstmaan"]}
MESS_ALIASES_JSON=

# Test mode and logs
ALLOW_FROM_ME=false
DEBUG_LOGS=false
LOG_ALL_GROUP_MESSAGES=false

# Use one or both:
TARGET_GROUP_IDS=12036302xxxxxxxx@g.us
TARGET_GROUP_NAMES=Coupons Group,Deals Team

# Private message template
# Supported placeholders:
# {{phone}}, {{keyword}}, {{keywords}}, {{group}}, {{message}}, {{MESS_NAME}}, {{MESS_TIME}}
REPLY_MESSAGE=I want to buy {{MESS_NAME}} {{MESS_TIME}} coupon. same number?

# Optional: prevent repeated replies to same sender for N seconds
REPLY_COOLDOWN_SECONDS=300

# Browser/runtime options
HEADLESS=true
AUTH_PATH=.wwebjs_auth
CLIENT_ID=coupon-bot
AUTO_RESTART_ON_DISCONNECT=true
RESTART_DELAY_MS=5000
DEDUPE_CACHE_SIZE=1000
MAX_RECENT_SENDERS=5000
PUPPETEER_EXECUTABLE_PATH=

# Optional health + keepalive
HEALTH_PORT=8787
KEEPALIVE_URL=
KEEPALIVE_INTERVAL_SECONDS=300

# Optional: print all group names + IDs on startup
LOG_GROUPS_ON_READY=true
GROUP_LIST_RETRY_ATTEMPTS=3
GROUP_LIST_RETRY_DELAY_MS=2000

# Control server
CONTROL_HOST=127.0.0.1
CONTROL_PORT=8788
REQUIRE_CONTROL_AUTH=false
CONTROL_AUTH_EMAIL=
CONTROL_AUTH_PASSWORD=
